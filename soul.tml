<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soul - Detalhes</title>
    <style>
        /* [O mesmo CSS da página de detalhes anterior] */
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: #0b0c10; color: #ffffff; padding: 40px 20px; }
        .container { max-width: 1100px; margin: 0 auto; }
        .btn-voltar { display: inline-flex; align-items: center; gap: 8px; background: transparent; border: 1px solid rgba(255, 255, 255, 0.2); color: #c5c6c7; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: bold; transition: all 0.2s ease; margin-bottom: 30px; }
        .btn-voltar:hover { border-color: #66fcf1; color: #66fcf1; transform: translateX(-3px); }
        .detalhe-wrapper { display: grid; grid-template-columns: 300px 1fr; gap: 40px; background: rgba(31, 40, 51, 0.3); border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border-radius: 16px; padding: 40px; }
        .poster-detalhe { background: #11141a; border-radius: 12px; height: 420px; display: flex; align-items: center; justify-content: center; font-size: 5rem; border: 1px solid rgba(255, 255, 255, 0.1); }
        .info-header h1 { font-size: 2.5rem; color: #ffffff; margin-bottom: 15px; line-height: 1.2; }
        .meta-detalhe { display: flex; flex-wrap: wrap; gap: 15px; font-size: 0.95rem; color: #95a5a6; align-items: center; margin-bottom: 25px; }
        .nota-grande { color: #f1c40f; font-weight: bold; font-size: 1.2rem; }
        .stream-badge-fixo { padding: 5px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; text-transform: uppercase; border: 1px solid #113CCF; background: rgba(17, 60, 207, 0.2); color: #547eff; }
        .divider { height: 1px; background: rgba(255, 255, 255, 0.1); margin: 25px 0; }
        .bloco-texto h3 { color: #66fcf1; font-size: 1.2rem; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
        .bloco-texto p { color: #c5c6c7; font-size: 1.05rem; line-height: 1.7; margin-bottom: 25px; }
        .ficha-tecnica { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; background: rgba(11, 12, 16, 0.5); padding: 20px; border-radius: 8px; }
        .ficha-item span { display: block; font-size: 0.85rem; color: #95a5a6; text-transform: uppercase; margin-bottom: 4px; }
        .ficha-item p { color: #ffffff; font-weight: 500; }
        @media (max-width: 800px) { .detalhe-wrapper { grid-template-columns: 1fr; gap: 30px;